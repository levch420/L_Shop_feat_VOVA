{
  "name": "l_shop",
  "version": "1.0.0",
  "description": "L_Shop — прототип кондитерского магазина (Express + TypeScript API, клиентский фронт)",
  "private": true,
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cross-env NODE_ENV=development tsx watch server/src/index.ts",
    "dev:client": "webpack serve --open --config ./webpack.config.js --env mode=dev",
    "build:client": "webpack --config ./webpack.config.js --env mode=prod",
    "build:server": "node ./node_modules/typescript/bin/tsc -p server/tsconfig.json",
    "build": "npm run build:client && npm run build:server",
    "start": "cross-env NODE_ENV=production node server/dist/index.js",
    "lint": "eslint . --ext .js,.ts",
    "format": "prettier --write \"src/**/*.{js,css}\" \"server/src/**/*.ts\""
  },
  "keywords": ["candy", "shop", "express", "typescript"],
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "express-session": "^1.18.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/node": "^20.11.30",
    "@typescript-eslint/eslint-plugin": "^7.3.1",
    "@typescript-eslint/parser": "^7.3.1",
    "clean-webpack-plugin": "^4.0.0",
    "concurrently": "^8.2.2",
    "copy-webpack-plugin": "^12.0.2",
    "cross-env": "^7.0.3",
    "css-loader": "^6.10.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-prettier": "^5.1.3",
    "html-webpack-plugin": "^5.6.0",
    "prettier": "3.2.5",
    "style-loader": "^3.3.4",
    "tsx": "^4.7.1",
    "typescript": "^5.4.3",
    "webpack": "^5.90.1",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.0",
    "webpack-merge": "^5.10.0"
  }
}
